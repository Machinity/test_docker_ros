{
  // VSCode Dev Container 설정
  // 이 파일이 있으면 VSCode가 "Reopen in Container" 팝업을 자동으로 띄워줌
  "name": "ROS2 Jazzy (Ubuntu Noble)",

  // 위 Dockerfile을 그대로 재사용
  "build": {
    "dockerfile": "../Dockerfile",
    "args": {
      "USERNAME": "ros",
      "USER_UID": "1000",
      "USER_GID": "1000"
    }
  },

  // 컨테이너 안에서의 작업 디렉토리
  "workspaceFolder": "/ros2_ws",
  "workspaceMount": "source=${localWorkspaceFolder},target=/ros2_ws,type=bind",

  // ROS2 환경 변수
  "containerEnv": {
    "DISPLAY": "unix:0",
    "ROS_DOMAIN_ID": "42",
    "ROS_LOCALHOST_ONLY": "0"
  },

  // 컨테이너 실행 옵션
  "runArgs": [
    "--net=host",
    "--pid=host",
    "--ipc=host",
    "--privileged",
    "-e", "DISPLAY=${localEnv:DISPLAY}"
  ],

  // X11 소켓 마운트 (RViz2 GUI용)
  "mounts": [
    "source=/tmp/.X11-unix,target=/tmp/.X11-unix,type=bind,consistency=cached"
  ],

  // 컨테이너 생성 후 자동 실행 명령
  // rosdep으로 패키지 의존성 자동 설치
  "postCreateCommand": "sudo rosdep update && rosdep install --from-paths src --ignore-src -y 2>/dev/null || echo 'src not found, skipping rosdep'",

  // VSCode 확장 프로그램 자동 설치
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",           // C++ 지원
        "ms-python.python",             // Python 지원
        "ms-iot.vscode-ros",            // ROS 패키지 지원
        "twxs.cmake",                   // CMake 지원
        "ms-vscode.cmake-tools",        // CMake 빌드 도구
        "eamodio.gitlens",              // Git 히스토리 시각화
        "smilerobotics.urdf",           // URDF 미리보기
        "ms-azuretools.vscode-docker"   // Docker 관리
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "python.defaultInterpreterPath": "/usr/bin/python3"
      }
    }
  },

  // 컨테이너 안에서 실행할 사용자
  "remoteUser": "ros"
}
